<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
		bootstrap="tests/bootstrap.php"
		colors="true"
		cacheDirectory=".phpunit.cache"
		failOnRisky="true"
		failOnWarning="true">
	<testsuites>
		<testsuite name="Phoenix">
			<directory>tests/phoenix</directory>
			<exclude>tests/phoenix/PhoenixTestCase.php</exclude>
		</testsuite>
	</testsuites>
	<source>
		<include>
			<directory>src</directory>
			<!-- public/ entry points are exercised by the smoke suite (smoke-php.yml);
			     the unit run reports them uncovered and qlty unions in the smoke clover. -->
			<directory>public</directory>
		</include>
	</source>
</phpunit>
