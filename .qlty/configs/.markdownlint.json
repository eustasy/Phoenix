{
  // All rules on by default; selectively configured or disabled below.
  "default": true,

  // MD003 — header style: ATX (#, ##, ###)
  "MD003": { "style": "atx" },

  // MD004 — unordered list marker: dash only
  "MD004": { "style": "dash" },

  // MD007 — unordered list indentation: 2 spaces (matches .editorconfig for Markdown)
  "MD007": { "indent": 2 },

  // MD013 — line length: allow paragraphs without formatting to multi-line
  "MD013": { "line_length": 9999 },

  // MD029 — ordered list prefix: ordered (1. 2. 3.)
  "MD029": { "style": "ordered" },

  // MD033 — inline HTML allowed (excluded in old .mdlrc.style.rb)
  "MD033": false,

  // MD041 — first line h1: not required (excluded in old .mdlrc.style.rb)
  "MD041": false,

  // MD055 — table pipe style: require leading + trailing pipes on every row
  "MD055": { "style": "leading_and_trailing" }
}
